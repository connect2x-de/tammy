platform :android do
    lane :screenshots do
        build_android_app(
            task: 'assemble',
            build_type: 'Debug'
        )
        build_android_app(
            task: 'assemble',
            build_type: 'AndroidTest'
        )
        capture_android_screenshots(
            locales: ["en-US", "de-DE"],
            clear_previous_screenshots: true,
            skip_open_summary: true,
            use_timestamp_suffix: false,
            app_apk_path: "build/outputs/apk/androidTest/googlePlay/debug/Tammy-googlePlay-debug-androidTest.apk",
            tests_apk_path: "build/outputs/apk/googlePlay/debug/Tammy-googlePlay-debug.apk",
            device_type: "phone",
            specific_device: "emulator-5564"
        )
        capture_android_screenshots(
            locales: ["en-US", "de-DE"],
            clear_previous_screenshots: true,
            skip_open_summary: true,
            use_timestamp_suffix: false,
            app_apk_path: "build/outputs/apk/androidTest/googlePlay/debug/Tammy-googlePlay-debug-androidTest.apk",
            tests_apk_path: "build/outputs/apk/googlePlay/debug/Tammy-googlePlay-debug.apk",
            device_type: "sevenInch",
            specific_device: "emulator-5566"
        )
        capture_android_screenshots(
            locales: ["en-US", "de-DE"],
            clear_previous_screenshots: true,
            skip_open_summary: true,
            use_timestamp_suffix: false,
            app_apk_path: "build/outputs/apk/androidTest/googlePlay/debug/Tammy-googlePlay-debug-androidTest.apk",
            tests_apk_path: "build/outputs/apk/googlePlay/debug/Tammy-googlePlay-debug.apk",
            device_type: "tenInch",
            specific_device: "emulator-5568"
        )
    end

    lane :releaseBeta do
        upload_to_play_store(
            track: 'beta',
            skip_upload_apk: true,
            aab: "build/outputs/bundle/googlePlayRelease/Tammy-googlePlay-release.aab",
            version_code: ENV['CI_PIPELINE_IID']
        )
    end

    lane :release do
        upload_to_play_store(
            skip_upload_apk: true,
            aab: "build/outputs/bundle/googlePlayRelease/Tammy-googlePlay-release.aab",
            version_code: ENV['CI_PIPELINE_IID']
        )
    end
end

platform :ios do
    lane :beta do
        timestamp = Time.now.strftime("%Y%m%d%H%M")
        increment_build_number(
            build_number: timestamp,
        )
        sync_code_signing(
            type: "appstore",
            readonly: true,
            git_branch: "main",
            clone_branch_directly: true,
            keychain_name: "apple_keychain.keychain",
            keychain_password: ENV['APPLE_KEYCHAIN_PASSWORD'],
        )
        update_code_signing_settings(
              use_automatic_signing: false,
              path: "iosApp/iosApp.xcodeproj",
              team_id: "C6CHAMK5QZ",
              bundle_identifier: "de.connect2x.tammy",
              targets: "Tammy for iOS",
              code_sign_identity: "Apple Distribution",
              profile_name: "match AppStore de.connect2x.tammy",
        )
        unlock_keychain(
            path: "apple_keychain.keychain",
            password: ENV['APPLE_KEYCHAIN_PASSWORD'],
            set_default: true,
        )
        build_app(project: "iosApp/iosApp.xcodeproj",
                  scheme: "Tammy for iOS",
                  export_method: "app-store",
                  configuration: "Release",
        )
        api_key = app_store_connect_api_key(
            key_id: "TRMFPS2J36",
            issuer_id: "f263cb3c-525b-41a1-a247-69b0d501ecde",
            key_filepath: "AuthKey_TRMFPS2J36.p8",
            duration: 1200, # optional (maximum 1200)
            in_house: false # optional but may be required if using match/sigh
        )
        upload_to_testflight(
            api_key: api_key,
            skip_submission: true,
            skip_waiting_for_build_processing: true,
            distribute_external: false,
        )
    end
end

platform :ios do
    lane :screenshots do
        capture_screenshots(
            scheme: "Tammy Screenshots"
        )
    end
end
